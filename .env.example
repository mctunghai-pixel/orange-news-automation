# Orange News Automation — Local dev environment
# Copy to .env and fill in real values
# Production uses GitHub Secrets, .env is local-only

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
FB_PAGE_ID=
FB_ACCESS_TOKEN=

# Telegram channel poster (v1)
# 1. BotFather (@BotFather)-аас /newbot командаар bot үүсгэн token-г энд тавь
# 2. Bot-оо channel-д ADMIN болгож, "Post Messages" эрх өгнө
# 3. Channel ID-г "@channelname" эсвэл "-1001234567890" хэлбэрээр тавь
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
